Version=1.0
Type=Application
Name=Wall-IT
Comment=A professional wallpaper manager for Linux
Exec=wallpaper-gui.py
Icon=wall-it
Terminal=false
Categories=Utility;Graphics;
Keywords=wallpaper;desktop;background;image;
StartupNotify=true
StartupWMClass=com.wallit.app
MimeType=image/jpeg;image/png;image/gif;image/bmp;